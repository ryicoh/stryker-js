{
  "$schema": "../../node_modules/@ryicoh/core/schema/stryker-schema.json",
  "testRunner": "tap",
  "concurrency": 1,
  "reporters": ["json", "clear-text", "html", "event-recorder"],
  "plugins": [
    "@ryicoh/tap-runner"
  ],
  "tap": {
    "nodeArgs": ["node_modules/ava/entrypoints/cli.mjs", "--tap", "--node-arguments='-r {{hookFile}}'"],
    "forceBail": false
  }
}
