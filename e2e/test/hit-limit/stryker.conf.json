{
  "$schema": "../../node_modules/@ryicoh/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["json"],
  "testRunner_comment": "Test runner is set in verify.ts",
  "coverageAnalysis": "perTest",
  "karma": {
    "projectType": "custom",
    "configFile": "karma.conf.cjs",
    "config": {}
  },
  "testRunnerNodeArgs": ["--experimental-vm-modules"],
  "concurrency": 1,
  "tap": {
    "testFiles": ["test/loop.tap.js"]
  },
  "plugins": [
    "@ryicoh/karma-runner",
    "@ryicoh/tap-runner",
    "@ryicoh/jasmine-runner",
    "@ryicoh/jest-runner",
    "@ryicoh/mocha-runner",
    "@ryicoh/cucumber-runner",
    "@ryicoh/vitest-runner"
  ]
}
