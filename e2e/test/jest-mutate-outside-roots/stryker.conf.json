{
  "$schema": "../../node_modules/@ryicoh/core/schema/stryker-schema.json",
  "tempDirName": "stryker-tmp",
  "reporters": ["json", "html", "clear-text", "progress", "event-recorder"],
  "testRunner": "jest",
  "jest": {
    "configFile": "jest.config.js"
  },
  "concurrency": 2,
  "coverageAnalysis": "perTest",
  "mutate": ["src/**/*.js"],
  "plugins": [
    "@ryicoh/jest-runner"
  ]
}
