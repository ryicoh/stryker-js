{
  "$schema": "../../node_modules/@ryicoh/core/schema/stryker-schema.json",
  "concurrency": 1,
  "concurrency_comment": "Concurrency 1 so we can test the reuse of the test runner for subsequent runs",
  "reporters": ["json", "html"],
  "ignoreStatic": true,
  "jasmineConfigFile": "jasmine.json",
  "testRunnerNodeArgs": ["--experimental-vm-modules"],
  "karma": {
    "configFile": "karma.conf.cjs"
  },
  "jest": {
    "configFile": "jest.config.json"
  },
  "tap": {
    "testFiles": ["spec/*.tap.js"]
  },
  "plugins": [
    "@ryicoh/karma-runner",
    "@ryicoh/tap-runner",
    "@ryicoh/jasmine-runner",
    "@ryicoh/jest-runner",
    "@ryicoh/mocha-runner",
    "@ryicoh/cucumber-runner",
    "@ryicoh/vitest-runner"
  ]
}
